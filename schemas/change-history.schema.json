{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-finops.dev/schemas/change-history.schema.json",
  "title": "ZWCA Artifact Change Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "change_id",
    "occurred_at",
    "project_id",
    "artifact_id",
    "artifact_type",
    "to_version",
    "change_summary",
    "evidence_basis"
  ],
  "properties": {
    "change_id": { "type": "string", "minLength": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "project_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "from_version": { "type": ["string", "null"] },
    "to_version": { "type": "string", "minLength": 1 },
    "change_summary": { "type": "string", "minLength": 1 },
    "affected_objects": { "type": "array", "items": { "type": "string" } },
    "evidence_basis": {
      "type": "string",
      "enum": ["measured", "estimated", "counterfactual"]
    },
    "decision_id": { "type": ["string", "null"] },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
